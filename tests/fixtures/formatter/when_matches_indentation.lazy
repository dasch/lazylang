// foo = x ->
//   when x matches
//     #ok then 1
//     #err then 2
foo = x ->
  when x matches
    #ok then 1
    #err then 2;




// x = 42
// result = when x matches
//   42 then y = 3
//   x * y
//   13 then z = 4
//
//   x + z
//
// { foo: foo #ok, result: result }
x = 42
result = when x matches
  42 then
    y = 3
    x * y

  13 then
    z = 4

    x + z

{ foo: foo #ok, result }



