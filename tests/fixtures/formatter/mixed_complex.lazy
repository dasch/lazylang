Array = import 'Array'
String = import 'String'

config = {
  name: "my-service"
  port: 8080
  url: "http://" + self.host
  debug: true if env == "development"
  replicas: 3 unless env == "development"
  tags: ["web", "api"]
}

validate = cfg ->
  assert cfg.port > 0 : "port must be positive"
  assert cfg.port < 65536 : "port out of range"
  cfg

names = ["Alice", "Bob", "Charlie"]
upper = [String.toUpperCase n for n in names]
result = Array.length upper

