// Benchmark: array operations — map, filter, fold over moderate-sized arrays.
xs = Array.map (x -> x * 2) (Range.toArray (1..500))
ys = Array.filter (x -> x > 100) xs
sum = Array.fold (acc -> x -> acc + x) 0 ys
sorted = Array.sort xs
reversed = Array.reverse sorted
uniq = Array.uniq (xs ++ xs)

{ sum, sortedLen: Array.length sorted, reversedLen: Array.length reversed, uniqLen: Array.length uniq }
